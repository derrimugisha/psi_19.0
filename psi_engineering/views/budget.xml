                <field name="bill_price" readonly="1"/>
                <field name="bill_amount" readonly="1"/>
            </xpath>
        </field>
    </record> -->

    <record id="timesheet_view_tree_user_extended" model="ir.ui.view">
        <field name="name">timesheet.view.tree.user.extended</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.timesheet_view_tree_user"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="bill_name"/>
                <field name="bill_product"/>
                <field name="bill_quantity"/>
                <field name="bill_price"/>
                <field name="bill_amount"/>
            </xpath>
        </field>
    </record>
    

</odoo>
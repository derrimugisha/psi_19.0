    <record id="res_partner_md_rule" model="ir.rule">
        <field name="name">Contacts: MD Access Rule</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="domain_force">[(1,'=',1)]</field> 
        <field name="groups" eval="[(4, ref('psi_engineering.group_mgt')),(4, ref('psi_engineering.group_md')),(4, ref('psi_engineering.group_finance')), (4, ref('psi_engineering.group_project_manager'))]"/> 
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="crm_lead_rule_management_view_all" model="ir.rule">
        <field name="name">Management and MD View All Leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="groups" eval="[(4, ref('psi_engineering.group_mgt')), (4, ref('psi_engineering.group_md'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="crm_lead_rule_non_management_view_own" model="ir.rule">
        <field name="name">Non-Management View Own Leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('user_id', '=', user.id),]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_stock_picking_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only See Receipts for Assigned Locations</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="domain_force">[('location_dest_id', 'in', user.employee_id.location_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="storekeeper_access_to_stock_picking" model="ir.model.access">
        <field name="name">stock.picking.storekeeper</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="group_id" ref="psi_engineering.group_storekeeper"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Rule for Inventory Adjustments -->
    <record id="rule_stock_inventory_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only Adjust Inventory for Assigned Locations</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="domain_force">[('location_id', 'in', user.employee_id.location_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule for Stock Reports (Quants) -->
    <record id="rule_stock_quant_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only View Stock Reports for Assigned Locations</field>
        <field name="model_id" ref="stock.model_stock_quant"/>
        <field name="domain_force">[('location_id', 'in', user.employee_id.location_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_stock_move_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only View Stock Moves(Moves Analysis) for Assigned Locations</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="domain_force">[
        '|',
        ('location_id', 'in', user.employee_id.location_ids.ids),
        ('location_dest_id', 'in', user.employee_id.location_ids.ids)
    ]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_stock_move_line_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only View Stock Move Lines(Moves History) for Assigned Locations</field>
        <field name="model_id" ref="stock.model_stock_move_line"/>
        <field name="domain_force">[
        '|',
        ('location_id', 'in', user.employee_id.location_ids.ids),
        ('location_dest_id', 'in', user.employee_id.location_ids.ids)
    ]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule for Item Requisitions -->
    <record id="rule_item_requisition_storekeeper" model="ir.rule">
        <field name="name">Storekeeper: Only Create Requisitions for Assigned Locations</field>
        <field name="model_id" ref="requisitions.model_item_requisition"/>
        <field name="domain_force">[('picking_type_id.default_location_dest_id', 'in', user.employee_id.location_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('psi_engineering.group_storekeeper'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record> 

</odoo>
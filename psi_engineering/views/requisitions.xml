    <record id="view_expense_type_wizard_form" model="ir.ui.view">
        <field name="name">expense.type.wizard.form</field>
        <field name="model">expense.type.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Expense Type">
                <group>
                    <field name="expense_type"/>
                    <field name="cash_requisition_id" readonly="1" force_save="1"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>



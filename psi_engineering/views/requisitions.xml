    <record id="view_item_requisition_form_inherit" model="ir.ui.view">
        <field name="name">item.requisition.form.inherit</field>
        <field name="model">item.requisition</field>
        <field name="inherit_id" ref="requisitions.item_requisition_form"/>
        <field name="arch" type="xml">


            <xpath expr="//form/header/button[@name='submit_for_approval']" position="after">
                <button confirm="Are you sure you want to approve this requisition?" name="approve" type="object" string="Project Coordinator/Manager/Engineer Approval" class="oe_highlight" invisible="state != 'submitted'" groups="psi_engineering.group_project_manager,psi_engineering.group_project_cordinator,psi_engineering.group_project_engineer"/>
            </xpath>
            <xpath expr="//form/header/button[@name='approve']" position="after">
                <button confirm="Are you sure you want to reject this requisition" name="reject_btn" type="object" string="Reject" class="oe_highlight" invisible="state != 'submitted'" groups="psi_engineering.group_project_manager,psi_engineering.group_project_cordinator,psi_engineering.group_project_engineer"/>
            </xpath>

            <xpath expr="//form/header/button[@name='approve']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form/header/button[@name='action_approve_item_requisition']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//form/header/button[@name='submit_for_approval']" position="after">
                <button confirm="Are you sure you want to approve this requisition" name="md_approve" type="object" string="Approve" class="oe_highlight" invisible="state != 'md_approval'" groups="psi_engineering.group_md"/>
            </xpath>
            <xpath expr="//form/header/button[@name='md_approve']" position="after">
                <button confirm="Are you sure you want to reject this requisition" name="reject_btn" type="object" string="Reject" class="oe_highlight" invisible="state != 'md_approval'" groups="psi_engineering.group_md"/>
            </xpath>

            <xpath expr="//form/header/button[@name='approve']" position="after">
                <button confirm="Are you sure you want to issue these items?" name="action_approve_item_requisition" type="object" string="Issue Items" class="oe_highlight" invisible="state != 'approved'" groups="psi_engineering.group_storekeeper"/>

            </xpath>




        </field>
    </record>

    <record id="item_requisition_form_inherit" model="ir.ui.view">
        <field name="name">item.requisition.form.inherited</field>
        <field name="model">item.requisition</field>
        <field name="inherit_id" ref="requisitions.item_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_uom']" position="after">
                <field name="cost" column_invisible="1"/>
                <field name="cost_subtotal" column_invisible="1" sum="Total Cost"/>
                <field name="price_unit" column_invisible="1"/>
                <field name="price_subtotal" column_invisible="1" sum="Total Sales Price"/>
            </xpath>
            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create_edit': True,  'no_create': True}</attribute>
            </xpath>

            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="project_id" column_invisible="1"/>
                <field name="budget_id" column_invisible="1"/>
                <field name="budget_line_id" options="{'no_create_edit': True,  'no_create': True}" domain="[('budget_analytic_id','=',parent.budget_id)]"/>
                <field name="analytic_account_id" column_invisible="1"/>
            </xpath>
            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_uom']" position="after">
                <field name="remaining_quantity" />
            </xpath>

            <xpath expr="//group/group/field[@name='delivery_date']" position="after">
                <field name="project_id" required="compute_required != True" />
                <field name="budget_id" required="compute_required != True" />
                <field name="picking_type_id" invisible="1"/>
                <field name="compute_required" invisible="1"/>
                <field name="vehicle_id" readonly="1"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="project_details" string="Project Details">
                    <group>
                        <field name="partner_id" readonly="1" force_save="1"/>
                        <field name="project_id" readonly="1" force_save="1"/>
                        <field name="task_id" readonly="1" force_save="1" invisible="1"/>
                        <field name="budget_id" readonly="1" force_save="1"/>
                        <field name="sub_task_id" readonly="1" force_save="1" invisible="1"/>
                        <field name="sale_order_id" readonly="1" force_save="1"/>
                        <field name="sale_order_line_id" readonly="1" force_save="1"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//form/header/field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,submitted,md_approval,approved,done"/>
            </xpath>
        </field>
    </record>



          <page name="Check List" string="Task Check List">
              <field name="checklist_ids" widget="one2many_list" context="{'default_project_id':project_id,'default_project_type_id':project_type_id}">
                  <list editable="bottom">
                      <field name="display_type" column_invisible="1"/>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_type_tree" model="ir.ui.view">
        <field name="name">project.type.list</field>
        <field name="model">project.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_project_type_form" model="ir.ui.view">
        <field name="name">project.type.form</field>
        <field name="model">project.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Project Type Name"/>
                        <h1>
                            <field name="name" readonly="0"/>
                        </h1>
                    </div>
                    <group>

                        <field name="milestone_template_ids">
                            <list>
                                <field name="name"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>

            </form>
        </field>
    </record>

    <record id="view_project_milestone_template_form" model="ir.ui.view">
        <field name="name">project.milestone.template.form</field>
        <field name="model">project.milestone.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">

                        <h1>
                            <field name="name" readonly="0"/>
                        </h1>
                    </div>
                    <group>

                        <field name="project_type_id" invisible="1"/>
                        <field name="milestone_item_ids" widget="one2many_list">
                            <list editable="bottom">
                                <control>
                                    <create name="add_item_control" string="Add a Milestone Item"/>
                                    <create name="add_section_control" string="Add a Section" context="{'default_display_type': 'line_section'}"/>
                                    <!-- <create name="add_note_control" string="Add a Note" context="{'default_display_type': 'line_note'}"/> -->
                                </control>

                                <field name="display_type" column_invisible="1"/>
                                <field name="no" required="1"/>
                                <field name="name" widget="section_and_note_text"/>
                                <field name="answer_type" invisible="display_type != False"/>
                                <field name="comments" invisible="display_type != False"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <!-- <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div> -->
            </form>
        </field>
    </record>
    <record id="view_project_milestone_item_tree" model="ir.ui.view">
        <field name="name">project.milestone.item.list</field>
        <field name="model">project.milestone.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="answer_type"/>
            </list>
        </field>
    </record>
    <record id="view_project_milestone_item_form" model="ir.ui.view">
        <field name="name">project.milestone.item.form</field>
        <field name="model">project.milestone.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="answer_type"/>
                        <field name="comments"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_project_milestone_form_inherit" model="ir.ui.view">
        <field name="name">project.milestone.form.inherit</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_form"/>
        <field name="arch" type="xml">

<odoo>
    <data noupdate="0">
        <record id="seq_res_partner_vendor" model="ir.sequence">
            <field name="name">Vendor Sequence</field>
            <field name="code">res.partner.vendor</field>
            <field name="prefix">V</field>
            <field name="padding">5</field>
        </record>

        <!-- Sequence for Customer -->
        <record id="seq_res_partner_customer" model="ir.sequence">
            <field name="name">Customer Sequence</field>
            <field name="code">res.partner.customer</field>
            <field name="prefix">C</field>
            <field name="padding">5</field>
        </record>

        <record id="seq_po_requisition" model="ir.sequence">
            <field name="name">Purchase Requisition</field>
            <field name="code">po.requisition</field>
            <field name="prefix">PR</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_product_product" model="ir.sequence">
            <field name="name">Product Internal Reference</field>
            <field name="code">product.product</field>
            <field name="prefix">IR</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
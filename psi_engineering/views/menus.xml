<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_cash_request" model="ir.actions.act_window">
        <field name="name">Cash Requests</field>
        <field name="res_model">cash.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_item_request" model="ir.actions.act_window">
        <field name="name">Item Requisitions</field>
        <field name="res_model">item.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record id="action_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Requisitions</field>
        <field name="res_model">po.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <!-- Action for Customers -->
    <record id="action_res_partner_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_customer', '>', 0)]</field>
    </record>

    <!-- Action for Vendors -->
    <record id="action_res_partner_vendors" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_vendor', '=', True)]</field>
    </record>

    <menuitem id="menu_res_partner_customers" name="Customers" parent="contacts.menu_contacts" action="action_res_partner_customers" sequence="-1"/>

    <!-- Vendor Menu Item -->
    <menuitem id="menu_res_partner_vendors" name="Vendors" parent="contacts.menu_contacts" action="action_res_partner_vendors" sequence="1"/>

</odoo>

<odoo>
  <data> 

    <record id="view_sale_order_form_inherit_cash_request" model="ir.ui.view">
      <field name="name">sale.order.form.inherit.cash.request</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <!-- Reference the sale order form view -->
      <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
          <button type="object" name="action_view_cash_requests" icon="fa-money" invisible="cash_request_count ==  0" class="oe_stat_button">
            <field name="cash_request_count" widget="statinfo" string="Cash Requisitions"/>
          </button>

          <button type="object" name="action_view_purchase_requests" icon="fa-book" invisible="purchase_request_count ==  0" class="oe_stat_button">
            <field name="purchase_request_count" widget="statinfo" string="Purchase Requisitions"/>
          </button>

          <button type="object" name="action_view_item_requests" icon="fa-truck" invisible="item_request_count ==  0" class="oe_stat_button">
            <field name="item_request_count" widget="statinfo" string="Item Requisitions"/>
          </button>
        </xpath>
         <xpath expr="//group/group/field[@name='partner_id']" position="attributes">
                <attribute name="domain">[('is_customer','=',True),]</attribute>
            </xpath>


      </field>
    </record>



    <record id="view_task_form_inherit_cash_request" model="ir.ui.view">
      <field name="name">task.form.inherit.cash.request</field>
      <field name="model">project.task</field>
      <field name="inherit_id" ref="project.view_task_form2"/>
      <!-- Reference the task form view -->
      <field name="arch" type="xml">
        <xpath expr="//div[@class='oe_button_box']" position="inside">
          <button type="object" name="action_view_cash_requests" icon="fa-money" invisible="1" class="oe_stat_button">
            <field name="cash_request_count" widget="statinfo" string="Cash Requisitions"/>
          </button>

          <button type="object" name="action_view_purchase_requests" icon="fa-book" invisible="1" class="oe_stat_button">
            <field name="purchase_request_count" widget="statinfo" string="Purchase Requisitions"/>
          </button>

          <button type="object" name="action_view_purchase_orders" icon="fa-book" invisible="0" class="oe_stat_button">
            <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
          </button>

          <button type="object" name="action_view_item_requests" icon="fa-truck" invisible="1" class="oe_stat_button">
            <field name="item_request_count" widget="statinfo" string="Material Internal Pickups"/>
          </button>
        </xpath>

        <xpath expr="//group/group/field[@name='tag_ids']" position="before">
            <field name="is_milestone"/>
            <field name="milestone_template_id" />
            <field name="attachment_ids" widget="many2many_binary"/>
        </xpath>
        <xpath expr="//group/group/field[@name='tag_ids']" position="after">
            <field name="checklist_completed" invisible="1"/>
            <button name="action_redirect_to_website_form" string="Fill Milestone Checklist on Website" type="object" class="oe_highlight" invisible="checklist_completed"/>
        </xpath>

        <xpath expr="//header" position="inside">

          <button name="action_create_cash_request" type="object" string="Create Cash Request" invisible="1" class="oe_highlight"/>

          <button name="action_create_item_request" type="object" string="Create Material Request" invisible="1" class="oe_highlight"/>

          <button name="action_create_purchase_request" type="object" string="Create Purchase Request" invisible="1" class="oe_highlight"/>
          <button name="action_create_purchase_order" type="object" string="Create Purchase Order" invisible="0" class="oe_highlight"/>
          

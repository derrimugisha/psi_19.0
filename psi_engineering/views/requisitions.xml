<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_po_request_form_inherit" model="ir.ui.view">
        <field name="name">purchase.request.form.inherit</field>
        <field name="model">po.requisition</field>
        <field name="inherit_id" ref="requisitions.po_requisition_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position='attributes'>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/sheet/div/div[@class='oe_title']/h1/field[@name='name']" position='before'>
                <h1>
                    <field name="pr_sequence" readonly="1"/>
                </h1>
            </xpath>
            <xpath expr="//form/header/button[@name='submit_btn']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='submit_btn']" position="after">
            <button name="submit_order" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                
            </xpath>
            <xpath expr="//form/header/button[@name='submit_for_approval']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='submit_order']" position="after">
                <button name="pm_approval" type="object" string="Approve" class="btn-primary" invisible="state != 'submitted'" />
            </xpath> 
            <xpath expr="//form/header/button[@name='pm_approval']" position="after">
                <button name="btn_proc_approval" type="object" string="Approve" class="btn-primary" invisible="state != 'procurement_approved'" groups="psi_engineering.group_procurement"/>
            </xpath> 
            <xpath expr="//form/header/button[@name='action_finance_approved']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//form/header/button[@name='btn_proc_approval']" position="after">
                <button name="submit_md_approval" type="object" string="Approve" class="btn-primary" invisible="state != 'finance_approved'" groups="psi_engineering.group_finance"/>
            </xpath>
            <xpath expr="//form/header/button[@name='action_approve_po_requisition']" position="attributes">
                <attribute name="invisible">state not in ['approved']</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="btn_md_approval" type="object" string="Approve" class="oe_highlight" invisible="state != 'md_approval'" groups="psi_engineering.group_md"/>
                <button name="action_reject" type="object" string="Reject" class="btn-danger" invisible="state not in ['submitted', 'procurement_approved','finance_approved', 'md_approval']" groups="psi_engineering.group_md,psi_engineering.group_finance,psi_engineering.group_procurement"/>
                <button name="cancel_order" type="object" string="Cancel" class="btn-secondary" invisible="state not in ['draft','procurement_approved', 'submitted', 'finance_approved', 'md_approval', 'approved']" groups="psi_engineering.group_md,psi_engineering.group_finance,psi_engineering.group_procurement,psi_engineering.group_project_manager"/>
                <button name="reset_draft" type="object" string="Reset Draft" class="btn-secondary" invisible="state not in ['cancel','submitted','procurement_approved', 'finance_approved', 'md_approval', 'approved']"/>
            </xpath>

            <xpath expr="//form/header/field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,submitted,procurement_approved,finance_approved,md_approval,approved,done,rejected,cancel"/>
            </xpath>

            <xpath expr="//field[@name='user']" position="after">
                <field name="project_id"/>
                <field name="destination_location_id"/>
                <field name="budget_id"/>
                <field name="project_manager_id"/>
                <field name="partner_ref"/>
                <field name="department_id" invisible="1"/>
                <field name="employee_manager_id" invisible="1"/>
                <field name="can_approve" invisible="1" readonly="0"/>

            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="project_details" string="Purchase Requisition Details">
                    <group>
                        <field name="reject_reason" invisible ="state != 'rejected'"/>
                        <field name="partner_id" readonly="1" force_save="1"/>
                        <field name="project_id" readonly="1" force_save="1"/>
                        <field name="task_id" readonly="1" force_save="1" invisible="1"/>
                        <field name="budget_id" readonly="1" force_save="1"/>
                        <field name="sub_task_id" readonly="1" force_save="1" invisible="1"/>
                        <field name="sale_order_id" readonly="1" force_save="1"/>
                        <field name="sale_order_line_id" readonly="1" force_save="1"/>
                    </group>
                </page>
            </xpath>

            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                <attribute name="domain">product_domain</attribute>
            </xpath>
            <xpath expr="//notebook/page/field[@name='order_line']/list" position="attributes">
                <attribute name="decoration-danger"> show_budget_warning == True</attribute>
            </xpath>

            <xpath expr="//notebook/page/field[@name='order_line']/list/field[@name='product_id']" position="before">
                <field name="project_id" column_invisible="1"/>
                <field name="product_domain" column_invisible="1"/>
                <field name="show_budget_warning" column_invisible="1"/>
                <field name="budget_id" column_invisible="1"/>
                <field name="budget_line_id" domain="[('budget_analytic_id','=',parent.budget_id)]"/>
                <field name="analytic_account_id" column_invisible="1"/>
            </xpath>

            <xpath expr="//notebook/page/field[@name='order_line2']/list/field[@name='product_id']" position="before">
                <field name="project_id" column_invisible="1"/>
                <field name="budget_id" column_invisible="1"/>
                <field name="budget_line_id" domain="[('budget_analytic_id','=',parent.budget_id)]"/>
                <field name="analytic_account_id" column_invisible="1"/>
            </xpath>
            <!-- <field expr="//notebook/page/field[@name='order_line2']" position="attributes">
                <attribute name="readonly">state not in ('draft','submitted','finance_approved','approved','procurement_approved')</attribute>
            </field> -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="invisible">state not in ['draft']</attribute>
            </xpath>
            <xpath expr="//notebook/page/field[@name='order_line2']/list/field[@name='price_unit']" position="attributes">
                <attribute name="groups">requisitions.purchase_group_manager,psi_engineering.group_procurement</attribute>
            </xpath>
            <!-- <xpath expr="//sheet" position="inside">
                <div class="oe_chatter">
                    <field name="activity_ids" widget="mail_activity"/>
                </div>
            </xpath> -->
        </field>
    </record>

    <record id="requisitions_po_requisition_list" model="ir.ui.view">
        <field name="name">purchase.requisition.list.inherit</field>
        <field name="model">po.requisition</field>
        <field name="inherit_id" ref="requisitions.po_requisition_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list//field[@name='name']" position="replace">
                <field name="pr_sequence" readonly="1"/>
            </xpath>
            <xpath expr="//list//field[@name='pr_sequence']" position="after">
                <field name="partner_ref"/>
            </xpath>
            
        </field>
    </record>

    <record id="view_item_requisition_tree_inherit" model="ir.ui.view">
        <field name="name">item.requisition.list.inherit</field>
        <field name="model">item.requisition</field>
        <field name="inherit_id" ref="requisitions.item_requisition_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='warehouse_id']" position="replace">
                <field name="project_id" string="Project ID" />
            </xpath>
        </field>
    </record>


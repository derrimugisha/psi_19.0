        <field name="category_id" ref="module_category_psi"/>
    </record>

    <record id="group_estimator" model="res.groups">
        <field name="name">Estimator</field>
        <field name="category_id" ref="module_category_psi"/>
    </record>

    <record id="group_department_manager" model="res.groups">
        <field name="name">Department Manager</field>
        <field name="category_id" ref="module_category_psi"/>
    </record>

    <!-- Adding the Storekeeper group -->
    <record id="group_storekeeper" model="res.groups">
        <field name="name">Storekeeper</field>
        <field name="category_id" ref="module_category_psi"/>
    </record>


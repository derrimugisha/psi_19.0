        </field>
    </record>

    <record id="project_milestone_tree" model="ir.ui.view">
        <field name="name">project.list</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_reached']" position="before">
                <field name="project_type_id" column_invisible='1'/>
                <field name="milestone_template_id"/>
            </xpath>

            <xpath expr="//field[@name='is_reached']" position="after">
                <button name="view_milestone" type="object" string="View Milestone"/>
            </xpath>
        </field>
    </record>

    <record id="view_project_milestone_checklist_tree" model="ir.ui.view">
        <field name="name">project.milestone.checklist.list</field>
        <field name="model">project.milestone.checklist</field>
        <field name="arch" type="xml">
            <list>
                <field name="project_id"/>
                <field name="milestone_id"/>
                <field name="name"/>
                <field name="display_type"/>
                <field name="answer_type"/>
                <field name="comments"/>
                <field name="remarks"/>
            </list>
        </field>
    </record>

    <record id="view_project_milestone_checklist_form" model="ir.ui.view">
        <field name="name">project.milestone.checklist.form</field>
        <field name="model">project.milestone.checklist</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="project_id"/>
                        <field name="milestone_id"/>
                        <field name="milestone_template_id"/>
                        <field name="project_type_id"/>
                        <field name="name"/>
                        <field name="display_type"/>
                    </group>

                    <group>
                        <field name="answer_type"/>
                        <field name="answer_pass_fail" invisible="answer_type !=  'pass_fail'"/>
                        <field name="answer_number" invisible="answer_type !=  'number'"/>
                        <field name="answer_text" invisible="answer_type !=  'text'"/>
                    </group>

                    <group>
                        <field name="comments"/>
                        <field name="remarks"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_project_milestone_images_tree" model="ir.ui.view">
        <field name="name">project.milestone.images.list</field>
        <field name="model">project.milestone.images</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="milestone_id"/>
                <field name="project_id"/>
                <field name="project_type_id"/>
            </list>
        </field>
    </record>

    <record id="view_project_milestone_images_form" model="ir.ui.view">
        <field name="name">project.milestone.images.form</field>
        <field name="model">project.milestone.images</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="milestone_id"/>
                        <field name="project_id"/>
                        <field name="project_type_id"/>
                        <field name="image" widget="image"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_project_type" model="ir.actions.act_window">
        <field name="name">Project Types</field>
        <field name="res_model">project.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_project_milestone_template" model="ir.actions.act_window">
        <field name="name">Milestone Templates</field>
        <field name="res_model">project.milestone.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_project_milestone_item" model="ir.actions.act_window">
        <field name="name">Milestone Items</field>
        <field name="res_model">project.milestone.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_project_milestone_item" model="ir.actions.act_window">
        <field name="name">Milestone Items</field>
        <field name="res_model">project.milestone.item</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem id="menu_project_type_root" name="Project Configuration" parent="project.menu_project_config" sequence="10"/>
    <menuitem id="menu_project_type" name="Project Types" parent="menu_project_type_root" action="action_project_type" sequence="1"/>
    <menuitem id="menu_project_milestone_template" name="Milestone Templates" parent="menu_project_type_root" action="action_project_milestone_template" sequence="2"/>
    <menuitem id="menu_project_milestone_item" name="Milestone Items" parent="menu_project_type_root" action="action_project_milestone_item" sequence="3"/>


</odoo>
